pipeline {
    agent any

    stages {

        stage('Hello Stage 1') {
            steps {
                sh './scripts/stage1.sh'
            }
        }

        stage('Hello Stage 2') {
            steps { 
                sh '''
                './scripts/stage2.sh'
                docker ps
                '''
            }
        }

    }

    post {
        success {
            echo 'Pipeline completed successfully!'
        }
        failure {
            echo 'Pipeline failed!'
        }
    }
}
