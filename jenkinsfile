pipeline {
    agent any

    stages {

        stage('Hello Stage 1') {
            steps {
                echo 'Hello from Stage 1 — Building the project'
            }
        }

        stage('Hello Stage 2') {
            steps {
                echo 'Hello from Stage 2 — Deploying the project'
            }
        }

    }

    post {
        success {
            echo 'Pipeline completed successfully!'
        }
        failure {
            echo 'Pipeline failed!'
        }
    }
}
